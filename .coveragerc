[run]
omit =
    */tests/*
    */ogx/templates/*
    .venv/*
    */ogx/cli/scripts/*
    */ogx_ui/*
    */ogx/distribution/ui/*
    */ogx/strong_typing/*
    */ogx/env.py
    */__init__.py

[report]
# Set fail_under to a few points below current coverage to avoid blocking
# existing PRs. Ratchet this threshold up over time as coverage improves.
fail_under = 53
show_missing = true
